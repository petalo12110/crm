# ── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm_dev

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────
# Minimum 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-minimum-32-chars

# Token lifetimes in seconds
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# ── Encryption (sensitive field encryption) ──────────────────
# 64 hex characters (32 bytes) — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Storage ──────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# Uncomment for S3:
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@crm.local

# ── Application ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
MAX_FILE_SIZE_MB=25

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=info
SWAGGER_ENABLED=true

# ── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
