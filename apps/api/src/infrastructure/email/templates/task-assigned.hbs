<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Task Assigned</title></head>
<body style="font-family:sans-serif;max-width:600px;margin:0 auto;padding:20px">
  <h2>New Task Assigned to You</h2>
  <p>Hello {{firstName}},</p>
  <p>You have been assigned a new task:</p>
  <p><strong>{{taskTitle}}</strong><br>Priority: {{priority}}<br>Due: {{dueDate}}</p>
  <p><a href="{{taskUrl}}">View task →</a></p>
  <p>— CRM System</p>
</body>
</html>
