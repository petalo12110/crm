# Used only by `pnpm build:android` (Vite --mode android loads this file
# automatically). Copy this to `.env.android` and fill in your computer's
# LAN IP address — the one your phone can actually reach it at, not
# "localhost" (localhost inside the Android app means the phone itself,
# not your computer).
#
# Find your LAN IP:
#   Mac/Linux: ifconfig | grep "inet " (look for 192.168.x.x or 10.x.x.x)
#   Windows:   ipconfig  (look for IPv4 Address)
#
# Your phone and computer must be on the same Wi-Fi network.

VITE_API_URL=http://192.168.1.100:3000
