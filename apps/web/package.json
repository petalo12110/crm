{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":     "vite",
    "dev:lan": "VITE_DEV_HOST=0.0.0.0 vite",
    "build":   "tsc && vite build",
    "preview": "vite preview",
    "lint":    "eslint src --ext .ts,.tsx",
    "build:android": "tsc && vite build --mode android",
    "cap:add:android": "cap add android",
    "cap:sync":        "cap sync android",
    "cap:open:android":"cap open android",
    "cap:assets":       "capacitor-assets generate --android",
    "android:test":    "pnpm build:android && pnpm cap:sync && pnpm cap:open:android"
  },
  "dependencies": {
    "@capacitor/android":   "^6.1.0",
    "@capacitor/core":      "^6.1.0",
    "@capacitor/status-bar":"^6.0.1",
    "@crm/shared":          "workspace:*",
    "@tanstack/react-query":"^5.51.1",
    "@tanstack/react-table":"^8.19.2",
    "axios":                "^1.7.2",
    "date-fns":             "^3.6.0",
    "lucide-react":         "^0.400.0",
    "react":                "^18.3.1",
    "react-dom":            "^18.3.1",
    "react-hook-form":      "^7.52.1",
    "react-router-dom":     "^6.24.1",
    "recharts":             "^2.12.7",
    "zod":                  "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/assets":    "^3.0.5",
    "@capacitor/cli":       "^6.1.0",
    "@types/react":         "^18.3.3",
    "@types/react-dom":     "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer":         "^10.4.19",
    "postcss":              "^8.4.39",
    "tailwindcss":          "^3.4.4",
    "typescript":           "^5.4.5",
    "vite":                 "^5.3.3"
  }
}
